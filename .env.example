# FlightWise — optional environment file
# --------------------------------------
# You do NOT need this file for the app to run. Copy to ".env" only if you want
# to set optional variables (e.g. future LLM features). The default planner uses
# template explanations and does not call OpenAI.

# Optional: longer, narrative explanations via OpenAI (scheduler is unchanged).
# Without OPENAI_API_KEY, explanations use the built-in detailed template.
# OPENAI_API_KEY=
# FLIGHTWISE_EXPLAIN_MODEL=gpt-4o-mini
# Set to 0 to force template explanations even if OPENAI_API_KEY is set.
# FLIGHTWISE_EXPLAIN_USE_LLM=1
